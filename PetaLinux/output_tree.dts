        can0_clk: can0_clk {
                #clock-cells = <0x0>;
                compatible = "fixed-factor-clock";
                clocks = <&clock_controller 0x60>;
                clock-div = <0x2>;
                clock-mult = <0x1>;
                phandle = <0x8e>;
        };

        can1_clk: can1_clk {
                #clock-cells = <0x0>;
