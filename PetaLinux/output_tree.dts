                                };

                                user-key@190 {
                                        reg = <0x190 0x20>;
                                };

                                user-key@1b0 {
                                        reg = <0x1b0 0x20>;
                                };

                                user-key@1d0 {
                                        reg = <0x1d0 0x20>;
                                };

                                user-key@1f0 {
                                        reg = <0x1f0 0x20>;
                                };
